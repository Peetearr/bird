<mujoco>
    <include file="pigeon.xml"/>
    <option timestep="0.01" integrator="RK4" gravity="0 0 -5" density="1.2" viscosity="0.00002" noslip_iterations="3"/>
    <!-- "4.905 0 -8.5" -->
    <asset>
        <texture type="skybox" builtin="gradient" 
            rgb1="0.6 0.7 0.9"
            rgb2="0.95 0.95 1.0"
            width="512" height="512"/>
        
         <texture name="light_grid" type="2d" builtin="checker" 
             width="512" height="512" 
             rgb1="0.7 0.7 0.7" 
             rgb2="0.9 0.9 0.9"/>
        <!-- <material name="floor_mat" texture="light_grid" 
                texrepeat="5 5" reflectance="0.3"/> -->

        <texture name="checkered_floor" type="2d" builtin="checker" 
             rgb1="0.2 0.2 0.2" rgb2="0.6 0.6 0.6" 
             width="512" height="512" 
             mark="cross" markrgb="0.8 0.8 0.8"/>
    
        <!-- Связываем текстуру с материалом, texrepeat контролирует частоту полос -->
        <material name="floor_mat" texture="checkered_floor" 
             texrepeat=".1 .1" texuniform="true" 
             reflectance="0.3" shininess="0.1"/>
    </asset>

    <worldbody>
        <!-- <geom name="ground" type="plane" size="2 1.5 0.1" pos="2 1.5 -100" rgba="1 1 1 .3"/> -->
        <geom name="floor" type="plane" size="200 200 0.05" 
          material="floor_mat" 
          pos="0 0 -1.5"/>
    </worldbody>

</mujoco>